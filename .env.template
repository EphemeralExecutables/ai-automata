# Gemini Daily Automation Config Template
# Copy this to .env and configure the fields.

# Comma-separated list of RSS feed URLs to parse articles from
RSS_FEEDS=https://news.ycombinator.com/rss,https://netflixtechblog.com/feed,https://blog.uber.com/category/engineering/feed,https://aws.amazon.com/blogs/architecture/feed

# Gemini model identifier (e.g. gemini-2.5-flash)
MODEL_NAME=gemini-2.5-flash

# Path where daily summary markdown reports should be saved
OUTPUT_PATH=./morning_summary.md

# Path to the Google Cloud client secret json file (OAuth Desktop Application credentials)
CLIENT_SECRET_PATH=../client_secret.json

# Path where the generated OAuth 2.0 user tokens are cached
TOKEN_PATH=../token.json
